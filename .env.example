# C# 백엔드(추후 연결) base url
VITE_API_BASE_URL=http://localhost:5000
# Optional: direct SignalR hub URL (if omitted, derived from VITE_API_BASE_URL)
# VITE_SIGNALR_HUB_URL=http://localhost:5000/hubs/chart

# 프론트만 먼저 개발할 때: mock 데이터 사용
VITE_USE_MOCK=true

# 시드 기본값 포함 여부 (true: 샘플 데이터 포함, false: 빈 배열만)
VITE_USE_SEED_DEFAULTS=true
