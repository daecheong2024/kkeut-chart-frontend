import React, { useMemo, useState } from "react";
import { TopBar } from "../../components/layout/TopBar";
import { Button } from "../../components/ui/Button";
import { Input } from "../../components/ui/Input";
import { Select } from "../../components/ui/Select";
import { Switch } from "../../components/ui/Switch";
import { useSettingsStore } from "../../stores/useSettingsStore";
import type { TicketItem, TicketRestrictionPreset, MembershipItem } from "../../types/settings";

import { Plus, Trash2, Search, X, Calendar } from "lucide-react";

/**
 * 티켓 설정 화면
 */
export default function TicketsSettingsPage() {
  const { settings, updateSettings } = useSettingsStore();
  const activeBranchId = settings.activeBranchId;

  const [items, setItems] = useState<TicketItem[]>([]);
  const [presets, setPresets] = useState<TicketRestrictionPreset[]>([]);
  const [memberships, setMemberships] = useState<MembershipItem[]>([]);
  const [loading, setLoading] = useState(false);
  const [fullConfig, setFullConfig] = useState<any>(null);

  // Load from backend on mount
  React.useEffect(() => {
    async function load() {
      if (!activeBranchId) return;
      try {
        setLoading(true);
        const config = await import("../../services/chartConfigService").then(m => m.chartConfigService.get(activeBranchId));
        if (config) {
          setFullConfig(config);
          if (config.tickets) {
            setItems(config.tickets.items || []);
            setPresets(config.tickets.presets || []);
            setMemberships(config.tickets.memberships || []);
          }
        }
      } catch (e) {
        console.error("Failed to load ticket settings", e);
      } finally {
        setLoading(false);
      }
    }
    load();
  }, [activeBranchId]);

  const [search, setSearch] = useState("");
  const [filterType, setFilterType] = useState<"all" | "session" | "period">("all");
  const [activeTab, setActiveTab] = useState<"tickets" | "memberships">("tickets");
  const [editingMembership, setEditingMembership] = useState<MembershipItem | null>(null);
  const [isAddingMembership, setIsAddingMembership] = useState(false);
  const dirty = useMemo(() => {
    if (!fullConfig?.tickets) return items.length > 0 || presets.length > 0 || memberships.length > 0;
    return JSON.stringify(items) !== JSON.stringify(fullConfig.tickets.items) ||
      JSON.stringify(presets) !== JSON.stringify(fullConfig.tickets.presets) ||
      JSON.stringify(memberships) !== JSON.stringify(fullConfig.tickets.memberships);
  }, [items, presets, fullConfig]);

  const save = async () => {
    if (!activeBranchId) return;
    try {
      const newTickets = { items, presets, memberships };
      const configToSave = { ...(fullConfig || {}), tickets: newTickets };
      await import("../../services/chartConfigService").then(m => m.chartConfigService.update(activeBranchId, configToSave));
      updateSettings({ tickets: newTickets });
      setFullConfig(configToSave);
      alert("저장되었습니다.");
    } catch (e) {
      console.error(e);
      alert("저장 실패");
    }
  };

  const revert = () => {
    if (confirm("변경사항을 취소하시겠습니까?")) {
      if (fullConfig?.tickets) {
        setItems(fullConfig.tickets.items || []);
        setPresets(fullConfig.tickets.presets || []);
        setMemberships(fullConfig.tickets.memberships || []);
      } else {
        setItems([]);
        setPresets([]);
        setMemberships([]);
      }
    }
  };

  // Filtered List
  const filtered = items.filter((it) => {
    if (filterType !== "all" && it.usageUnit !== filterType) return false;
    if (search) {
      const q = search.toLowerCase();
      return (
        it.name.toLowerCase().includes(q) ||
        it.code.toLowerCase().includes(q)
      );
    }
    return true;
  });

  // Modal State (Draft)
  // Modal State (Draft)
  const [editingItem, setEditingItem] = useState<TicketItem | null>(null);
  const isModalOpen = editingItem !== null;

  // Preset Manager State
  const [isPresetMgrOpen, setIsPresetMgrOpen] = useState(false);
  const [newPresetDraft, setNewPresetDraft] = useState<Partial<TicketRestrictionPreset>>({});

  const handleCreate = () => {
    // Auto-generate code: Find max Axxxxxxx and increment
    const codes = items
      .map(i => i.code)
      .filter(c => /^A\d{7}$/.test(c))
      .map(c => parseInt(c.substring(1), 10));

    let nextCode = "A1000001";
    if (codes.length > 0) {
      const max = Math.max(...codes);
      nextCode = `A${(max + 1).toString().padStart(7, '0')}`;
    }

    const newItem: TicketItem = {
      id: `t_${Math.random().toString(36).substr(2, 9)}`,
      code: nextCode,
      name: "",
      usageUnit: "session",
      totalCount: 5,
      price: 0,
      enabled: true,
      autoTodoEnabled: false,
    };
    // Detached state: Do not add to items yet
    setEditingItem(newItem);
  };

  const handleDelete = (id: string) => {
    if (confirm("정말 삭제하시겠습니까?")) {
      setItems(items.filter((i) => i.id !== id));
    }
  };

  const handleEdit = (item: TicketItem) => {
    setEditingItem({ ...item }); // Clone for draft
  };

  const updateDraft = (patch: Partial<TicketItem>) => {
    setEditingItem((prev) => (prev ? { ...prev, ...patch } : null));
  };

  return (
    <div className="flex min-h-0 flex-1 flex-col">
      <TopBar title="설정 > 티켓" />

      <div className="flex-1 overflow-y-auto p-6">
        {/* Tab Navigation */}
        <div className="mb-6 flex items-center gap-4 border-b border-gray-200">
          <button
            onClick={() => setActiveTab("tickets")}
            className={`pb-3 px-1 text-sm font-bold transition ${activeTab === "tickets"
                ? "border-b-2 border-[rgb(var(--kkeut-primary))] text-[rgb(var(--kkeut-primary))]"
                : "text-gray-500 hover:text-gray-700"
              }`}
          >
            티켓 관리
          </button>
          <button
            onClick={() => setActiveTab("memberships")}
            className={`pb-3 px-1 text-sm font-bold transition ${activeTab === "memberships"
                ? "border-b-2 border-[rgb(var(--kkeut-primary))] text-[rgb(var(--kkeut-primary))]"
                : "text-gray-500 hover:text-gray-700"
              }`}
          >
            회원권 관리
          </button>
        </div>

        {/* Tickets Section */}
        {activeTab === "tickets" && (
          <div>
            {/* Header Actions */}
            <div className="flex flex-wrap items-center justify-between gap-3">
              <div>
                <div className="text-lg font-extrabold">티켓 관리</div>
                <div className="mt-1 text-sm text-gray-600">
                  시술/관리 티켓(패키지) 정보를 등록합니다. 결제 시 사용되며 잔여 횟수가 관리됩니다.
                </div>
              </div>
              <div className="flex items-center gap-2">
                <Button variant="primary" onClick={save} disabled={!dirty}>
                  저장
                </Button>
                <Button variant="outline" onClick={revert} disabled={!dirty}>
                  되돌리기
                </Button>
              </div>
            </div>

            {/* Toolbar */}
            <div className="mt-6 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-[rgb(var(--kkeut-border))] bg-white p-3">
              <div className="flex items-center gap-2">
                <div className="relative">
                  <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" />
                  <Input
                    className="pl-9 w-[240px]"
                    placeholder="코드/티켓명 검색"
                    value={search}
                    onChange={(e) => setSearch(e.target.value)}
                  />
                </div>
                <div className="flex rounded-lg border border-[rgb(var(--kkeut-border))] bg-gray-50 p-1">
                  {(["all", "session", "period"] as const).map((t) => (
                    <button
                      key={t}
                      onClick={() => setFilterType(t)}
                      className={`rounded-md px-3 py-1.5 text-xs font-bold transition ${filterType === t
                        ? "bg-white text-gray-900 shadow-sm"
                        : "text-gray-500 hover:text-gray-700"
                        }`}
                    >
                      {t === "all" ? "전체" : t === "session" ? "회수권" : "기간권"}
                    </button>
                  ))}
                </div>
              </div>
              <div className="flex gap-2">
                <Button variant="outline" onClick={() => {
                  setNewPresetDraft({ allowedDays: [0, 1, 2, 3, 4, 5, 6] });
                  setIsPresetMgrOpen(true);
                }}>
                  <Calendar className="h-4 w-4" />
                  요일권 관리
                </Button>
                <Button variant="outline" onClick={handleCreate}>
                  <Plus className="h-4 w-4" />
                  티켓 등록
                </Button>
              </div>
            </div>

            {/* List */}
            <div className="mt-4 overflow-hidden rounded-2xl border border-[rgb(var(--kkeut-border))] bg-white shadow-sm">
              <table className="min-w-full text-left text-sm">
                <thead className="bg-gray-50 text-gray-500">
                  <tr>
                    <th className="px-4 py-3 font-medium">코드</th>
                    <th className="px-4 py-3 font-medium">티켓명</th>
                    <th className="px-4 py-3 font-medium">유형</th>
                    <th className="px-4 py-3 font-medium">횟수/기간</th>
                    <th className="px-4 py-3 font-medium">가격</th>
                    <th className="px-4 py-3 font-medium">요일권</th>
                    <th className="px-4 py-3 font-medium">자동할일</th>
                    <th className="px-4 py-3 font-medium">사용</th>
                    <th className="px-4 py-3 font-medium text-right">관리</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-[rgb(var(--kkeut-border))]">
                  {filtered.length === 0 ? (
                    <tr>
                      <td colSpan={9} className="py-8 text-center text-gray-400">
                        등록된 티켓이 없습니다.
                      </td>
                    </tr>
                  ) : (
                    filtered.map((item) => (
                      <tr key={item.id} className="hover:bg-gray-50">
                        <td className="px-4 py-3 font-mono text-xs">{item.code || "-"}</td>
                        <td className="px-4 py-3 font-bold text-gray-900">{item.name}</td>
                        <td className="px-4 py-3">
                          <span
                            className={`inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ${item.usageUnit === "session"
                              ? "bg-blue-50 text-blue-700"
                              : "bg-green-50 text-green-700"
                              }`}
                          >
                            {item.usageUnit === "session" ? "회수권" : "기간권"}
                          </span>
                        </td>
                        <td className="px-4 py-3">
                          {item.usageUnit === "session"
                            ? `${item.totalCount}회`
                            : `${item.validDays}일`}
                        </td>
                        <td className="px-4 py-3 text-gray-600">
                          {item.price?.toLocaleString()}원
                        </td>
                        <td className="px-4 py-3">
                          {(() => {
                            // Find exact match with preset
                            const match = presets.find(p =>
                              JSON.stringify(p.allowedDays?.sort()) === JSON.stringify(item.allowedDays?.sort()) &&
                              JSON.stringify(p.allowedTimeRange) === JSON.stringify(item.allowedTimeRange)
                            );

                            if (match) return <span className="inline-flex items-center rounded-md bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700">{match.label}</span>;

                            // If no match but restrictions exist
                            const hasDays = item.allowedDays && item.allowedDays.length > 0 && item.allowedDays.length < 7;
                            const hasTime = item.allowedTimeRange?.start || item.allowedTimeRange?.end;

                            if (hasDays || hasTime) return <span className="text-xs text-gray-500">직접 설정</span>;
                            return <span className="text-xs text-gray-300">-</span>;
                          })()}
                        </td>
                        <td className="px-4 py-3">
                          {item.autoTodoEnabled ? (
                            <span className="text-xs text-blue-600">ON</span>
                          ) : (
                            <span className="text-xs text-gray-400">OFF</span>
                          )}
                        </td>
                        <td className="px-4 py-3">
                          <Switch
                            checked={item.enabled}
                            onCheckedChange={(v) => {
                              setItems(prev => prev.map(i => i.id === item.id ? { ...i, enabled: v } : i));
                            }}
                          />
                        </td>
                        <td className="px-4 py-3 text-right">
                          <div className="flex items-center justify-end gap-2">
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleEdit(item)}
                            >
                              수정
                            </Button>
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleDelete(item.id)}
                            >
                              <Trash2 className="h-4 w-4" />
                            </Button>
                          </div>
                        </td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>

            <div className="mt-6 rounded-xl bg-blue-50 p-4 text-sm text-blue-700">
              <p className="font-bold">ⓘ 안내</p>
              <p className="mt-1">
                향후 API 연동 시 고객 티켓(발행 인스턴스) + 사용 이력(ledger)로 잔여/사용내역을
                동적으로 계산합니다.
              </p>
            </div>
          </div>

      {/* Edit Modal */}
        {isModalOpen && editingItem && (
          <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 duration-200 animate-in fade-in">
            <div className="w-full max-w-lg rounded-2xl bg-white p-6 shadow-xl animate-in zoom-in-95">
              <div className="flex items-center justify-between mb-6">
                <h3 className="text-lg font-bold">티켓 정보 수정</h3>
                <button
                  onClick={() => setEditingItem(null)}
                  className="text-gray-400 hover:text-gray-600"
                >
                  <X className="h-5 w-5" />
                </button>
              </div>

              <div className="space-y-4">
                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <label className="mb-1 block text-xs font-bold text-gray-500">코드</label>
                    <Input
                      value={editingItem.code}
                      onChange={(e) => updateDraft({ code: e.target.value })}
                      placeholder="예: T001"
                    />
                  </div>
                  <div>
                    <label className="mb-1 block text-xs font-bold text-gray-500">가격</label>
                    <Input
                      type="number"
                      value={editingItem.price || 0}
                      onChange={(e) => updateDraft({ price: Number(e.target.value) })}
                      placeholder="0"
                    />
                  </div>
                </div>

                <div>
                  <label className="mb-1 block text-xs font-bold text-gray-500">티켓명</label>
                  <Input
                    value={editingItem.name}
                    onChange={(e) => updateDraft({ name: e.target.value })}
                    placeholder="티켓 이름을 입력하세요"
                  />
                </div>

                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <label className="mb-1 block text-xs font-bold text-gray-500">유형</label>
                    <Select
                      value={editingItem.usageUnit}
                      onChange={(e) =>
                        updateDraft({ usageUnit: e.target.value as "session" | "period" })
                      }
                    >
                      <option value="session">회수권 (횟수 차감)</option>
                      <option value="period">기간권 (날짜 경과)</option>
                    </Select>
                  </div>
                  <div>
                    {editingItem.usageUnit === "session" ? (
                      <div className="space-y-4">
                        <div>
                          <label className="mb-1 block text-xs font-bold text-gray-500">제공 횟수</label>
                          <Input
                            type="number"
                            min={1}
                            value={editingItem.totalCount || 1}
                            onChange={(e) =>
                              updateDraft({ totalCount: Number(e.target.value) })
                            }
                          />
                        </div>
                        <div>
                          <label className="mb-1 block text-xs font-bold text-gray-500">최소 주기(일, 0=제한없음)</label>
                          <Input
                            type="number"
                            min={0}
                            value={editingItem.minIntervalDays || 0}
                            onChange={(e) =>
                              updateDraft({ minIntervalDays: Number(e.target.value) })
                            }
                            placeholder="0"
                          />
                        </div>
                      </div>
                    ) : (
                      <div className="space-y-4">
                        <div>
                          <label className="mb-1 block text-xs font-bold text-gray-500">유효 기간(일)</label>
                          <Input
                            type="number"
                            min={1}
                            value={editingItem.validDays || 30}
                            onChange={(e) =>
                              updateDraft({ validDays: Number(e.target.value) })
                            }
                            placeholder="예: 365"
                          />
                        </div>
                        <div className="grid grid-cols-2 gap-4">
                          <div>
                            <label className="mb-1 block text-xs font-bold text-gray-500">최소 주기(일)</label>
                            <Input
                              type="number"
                              min={0}
                              value={editingItem.minIntervalDays || 0}
                              onChange={(e) =>
                                updateDraft({ minIntervalDays: Number(e.target.value) })
                              }
                              placeholder="0 (제한없음)"
                            />
                          </div>
                          <div>
                            <label className="mb-1 block text-xs font-bold text-gray-500">최대 이용 횟수</label>
                            <Input
                              type="number"
                              min={0}
                              value={editingItem.maxTotalCount || 0}
                              onChange={(e) =>
                                updateDraft({ maxTotalCount: Number(e.target.value) })
                              }
                              placeholder="0 (무제한)"
                            />
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                </div>

                {/* Usage Restrictions */}
                <div className="rounded-xl border border-[rgb(var(--kkeut-border))] bg-white p-4">
                  <div className="mb-4 flex items-center justify-between">
                    <div className="text-sm font-bold text-gray-900">이용 제한 설정</div>
                    <div className="flex items-center gap-2">
                      <span className="text-xs text-gray-400">요일권 불러오기:</span>
                      <div className="flex gap-2">
                        <Select
                          value=""
                          onChange={(e) => {
                            const val = e.target.value;
                            const p = presets.find(x => x.id === val);
                            if (p) {
                              // Deep clone values to ensure state update triggers
                              const newDays = p.allowedDays ? [...p.allowedDays] : undefined;
                              const newTime = p.allowedTimeRange ? { ...p.allowedTimeRange } : undefined;
                              updateDraft({ allowedDays: newDays, allowedTimeRange: newTime });
                            }
                          }}
                        >
                          <option value="" disabled>요일권 선택 ({presets.length}개)...</option>
                          {presets.map(p => (
                            <option key={p.id} value={p.id}>{p.label}</option>
                          ))}
                        </Select>
                      </div>
                      <Button
                        variant="outline"
                        size="sm"
                        onClick={() => {
                          const name = prompt("현재 요일/시간 설정을 요일권으로 저장합니다.\n요일권 이름을 입력하세요.");
                          if (name) {
                            const newPreset: TicketRestrictionPreset = {
                              id: Math.random().toString(36).substr(2, 9),
                              label: name,
                              allowedDays: editingItem.allowedDays,
                              allowedTimeRange: editingItem.allowedTimeRange
                            };
                            setPresets(prev => [...prev, newPreset]);
                          }
                        }}
                        className="h-7 text-xs"
                      >
                        <Plus className="mr-1 h-3 w-3" />
                        요일권 저장
                      </Button>
                    </div>
                  </div>

                  <div className="space-y-4">
                    {/* Days */}
                    <div>
                      <label className="mb-2 block text-xs font-bold text-gray-500">이용 가능 요일</label>
                      <div className="flex flex-wrap gap-2">
                        {["일", "월", "화", "수", "목", "금", "토"].map((dayName, idx) => {
                          const isSelected = !editingItem.allowedDays || editingItem.allowedDays.includes(idx);
                          const isRestrictedMode = !!editingItem.allowedDays; // If valid array exists, we are in restricted mode. If undefined, all allowed (but UI shows all selected)

                          // Handling:
                          // If allowedDays is undefined, it implies ALL allowed.
                          // When user clicks one, we initialize array with just that one? Or array with all others removed?
                          // Let's adopt logic: undefined = ALL. If user CLICKS one while undefined, switch to Restricted Mode.
                          // Actually simplified logic: 
                          // Render: If allowedDays is undefined, ALL are "active".
                          // Click: 
                          //   If currently ALL (undefined), clicking one 'deselects' it? No, usually you want to "select allowed".
                          //   Let's say: Default ALL. Click toggles.
                          //   If undefined, treat as [0,1,2,3,4,5,6].

                          const currentDays = editingItem.allowedDays ?? [0, 1, 2, 3, 4, 5, 6];
                          const active = currentDays.includes(idx);

                          return (
                            <button
                              key={idx}
                              className={`h-8 w-8 rounded-full text-xs font-bold transition-colors ${active
                                ? (idx === 0 ? "bg-red-100 text-red-600" : idx === 6 ? "bg-blue-100 text-blue-600" : "bg-gray-800 text-white")
                                : "bg-gray-100 text-gray-400"
                                }`}
                              onClick={() => {
                                let newDays = [...currentDays];
                                if (newDays.includes(idx)) {
                                  newDays = newDays.filter(d => d !== idx);
                                } else {
                                  newDays.push(idx);
                                }
                                updateDraft({ allowedDays: newDays });
                              }}
                            >
                              {dayName}
                            </button>
                          );
                        })}
                      </div>
                      <p className="mt-1 text-[10px] text-gray-400">선택된 요일에만 티켓을 사용할 수 있습니다.</p>
                    </div>

                    {/* Time Range */}
                    <div>
                      <label className="mb-2 block text-xs font-bold text-gray-500">이용 가능 시간</label>
                      <div className="flex items-center gap-2">
                        <Input
                          type="time"
                          className="w-32"
                          value={editingItem.allowedTimeRange?.start || ""}
                          onChange={(e) => updateDraft({
                            allowedTimeRange: {
                              start: e.target.value,
                              end: editingItem.allowedTimeRange?.end || ""
                            }
                          })}
                        />
                        <span className="text-gray-400">~</span>
                        <Input
                          type="time"
                          className="w-32"
                          value={editingItem.allowedTimeRange?.end || ""}
                          onChange={(e) => updateDraft({
                            allowedTimeRange: {
                              start: editingItem.allowedTimeRange?.start || "",
                              end: e.target.value
                            }
                          })}
                        />
                      </div>
                      <p className="mt-1 text-[10px] text-gray-400">입력된 시간 내에만 예약/사용이 가능합니다. (비워두면 제한 없음)</p>
                    </div>
                  </div>
                </div>

                <div className="rounded-xl border border-[rgb(var(--kkeut-border))] bg-gray-50 p-4">
                  <div className="flex items-center justify-between">
                    <div>
                      <div className="text-sm font-bold text-gray-900">자동 할일 생성</div>
                      <div className="text-xs text-gray-500">티켓 소진 시 자동으로 할일을 생성합니다.</div>
                    </div>
                    <Switch
                      checked={editingItem.autoTodoEnabled}
                      onCheckedChange={(v) => updateDraft({ autoTodoEnabled: v })}
                    />
                  </div>
                  {editingItem.autoTodoEnabled && (
                    <div className="mt-3">
                      <label className="mb-1 block text-xs font-bold text-gray-500">할일 제목 템플릿</label>
                      <Input
                        value={editingItem.autoTodoTitleTemplate || ""}
                        onChange={(e) =>
                          updateDraft({ autoTodoTitleTemplate: e.target.value })
                        }
                        placeholder="예: {patient}님 시술 준비"
                      />
                    </div>
                  )}
                </div>
              </div>

              <div className="mt-6 flex justify-end gap-2">
                <Button variant="outline" onClick={() => setEditingItem(null)}>
                  취소
                </Button>
                <Button variant="primary" onClick={() => {
                  if (!editingItem) return;
                  // Check duplicates
                  const isDuplicate = items.some(it =>
                    it.id !== editingItem.id &&
                    it.code.trim().toLowerCase() === editingItem.code.trim().toLowerCase()
                  );

                  if (isDuplicate) {
                    alert("이미 존재하는 코드입니다. 다른 코드를 입력해주세요.");
                    return;
                  }

                  if (!editingItem.code.trim()) {
                    alert("코드를 입력해주세요.");
                    return;
                  }

                  if (!editingItem.name.trim()) {
                    alert("티켓명을 입력해주세요.");
                    return;
                  }

                  // If valid, apply changes to items
                  const exists = items.some(it => it.id === editingItem.id);
                  if (exists) {
                    setItems(prev => prev.map(it => it.id === editingItem.id ? editingItem : it));
                  } else {
                    setItems(prev => [editingItem, ...prev]);
                  }

                  setEditingItem(null);
                }}>
                  적용
                </Button>
              </div>
            </div>
          </div >
        )}

        {/* Preset Manager Modal */}
        {isPresetMgrOpen && (
          <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 duration-200 animate-in fade-in">
            <div className="w-full max-w-lg rounded-2xl bg-white p-6 shadow-xl animate-in zoom-in-95">
              <div className="flex items-center justify-between mb-6">
                <h3 className="text-lg font-bold">요일권 설정 관리</h3>
                <button
                  onClick={() => setIsPresetMgrOpen(false)}
                  className="text-gray-400 hover:text-gray-600"
                >
                  <X className="h-5 w-5" />
                </button>
              </div>

              <div className="mb-6 space-y-2">
                <div className="text-sm font-bold text-gray-900">등록된 요일권</div>
                {presets.length === 0 ? (
                  <div className="rounded-lg border border-dashed p-4 text-center text-xs text-gray-400">등록된 요일권이 없습니다.</div>
                ) : (
                  <div className="space-y-2">
                    {presets.map(p => (
                      <div key={p.id} className="flex items-center justify-between rounded-lg border border-gray-100 bg-gray-50 px-3 py-2">
                        <div>
                          <div className="text-sm font-bold">{p.label}</div>
                          <div className="text-xs text-gray-500">
                            {/* Simple summary */}
                            {(!p.allowedDays || p.allowedDays.length === 7) ? "모든 요일" : ["일", "월", "화", "수", "목", "금", "토"].filter((_, i) => p.allowedDays?.includes(i)).join(", ")}
                            ·
                            {(!p.allowedTimeRange?.start && !p.allowedTimeRange?.end) ? " 시간제한 없음" : ` ${p.allowedTimeRange.start || "00:00"} ~ ${p.allowedTimeRange.end || "23:59"}`}
                          </div>
                        </div>
                        <button
                          onClick={() => {
                            if (confirm("삭제하시겠습니까?")) setPresets(prev => prev.filter(x => x.id !== p.id));
                          }}
                          className="p-1 text-gray-400 hover:text-red-500"
                        >
                          <Trash2 className="h-4 w-4" />
                        </button>
                      </div>
                    ))}
                  </div>
                )}
              </div>

              <div className="border-t border-gray-100 pt-4">
                <div className="mb-3 text-sm font-bold text-gray-900">새 요일권 등록</div>
                <div className="space-y-3 rounded-xl border border-gray-100 bg-gray-50 p-3">
                  <div>
                    <label className="mb-1 block text-xs font-bold text-gray-500">이름</label>
                    <Input
                      value={newPresetDraft.label || ""}
                      onChange={(e) => setNewPresetDraft(prev => ({ ...prev, label: e.target.value }))}
                      placeholder="예: 평일 오전"
                    />
                  </div>
                  <div>
                    <label className="mb-1 block text-xs font-bold text-gray-500">요일</label>
                    <div className="flex flex-wrap gap-2">
                      {["일", "월", "화", "수", "목", "금", "토"].map((dayName, idx) => {
                        const current = newPresetDraft.allowedDays ?? [];
                        const active = current.includes(idx);
                        return (
                          <button
                            key={idx}
                            onClick={() => {
                              const newDays = active ? current.filter(d => d !== idx) : [...current, idx];
                              setNewPresetDraft(prev => ({ ...prev, allowedDays: newDays }));
                            }}
                            className={`h-7 w-7 rounded-full text-xs font-bold ${active ? "bg-gray-800 text-white" : "bg-white text-gray-400 border border-gray-200"}`}
                          >
                            {dayName}
                          </button>
                        );
                      })}
                    </div>
                  </div>
                  <div>
                    <label className="mb-1 block text-xs font-bold text-gray-500">시간</label>
                    <div className="flex items-center gap-2">
                      <Input
                        type="time"
                        className="w-32"
                        value={newPresetDraft.allowedTimeRange?.start || ""}
                        onChange={(e) => setNewPresetDraft(prev => ({
                          ...prev,
                          allowedTimeRange: { start: e.target.value, end: prev.allowedTimeRange?.end || "" }
                        }))}
                      />
                      <span className="text-gray-400">~</span>
                      <Input
                        type="time"
                        className="w-32"
                        value={newPresetDraft.allowedTimeRange?.end || ""}
                        onChange={(e) => setNewPresetDraft(prev => ({
                          ...prev,
                          allowedTimeRange: { start: prev.allowedTimeRange?.start || "", end: e.target.value }
                        }))}
                      />
                    </div>
                  </div>

                  <div className="flex justify-end pt-2">
                    <Button
                      variant="primary"
                      size="sm"
                      disabled={!newPresetDraft.label}
                      onClick={() => {
                        if (!newPresetDraft.label) return;
                        const newPreset: TicketRestrictionPreset = {
                          id: Math.random().toString(36).substr(2, 9),
                          label: newPresetDraft.label,
                          allowedDays: newPresetDraft.allowedDays,
                          allowedTimeRange: newPresetDraft.allowedTimeRange
                        };
                        setPresets(prev => [...prev, newPreset]);
                        setNewPresetDraft({ allowedDays: [] }); // Reset
                      }}
                    >
                      <Plus className="mr-1 h-3 w-3" />
                      추가
                    </Button>
                  </div>

                </div>
        )}

                {/* Membership Management Section */}
                {activeTab === "memberships" && (
                  <div>
                    {/* Header Actions */}
                    <div className="flex flex-wrap items-center justify-between gap-3 mb-6">
                      <div>
                        <div className="text-lg font-extrabold">회원권 관리</div>
                        <div className="mt-1 text-sm text-gray-600">
                          회원권 정보를 등록하고 관리합니다. 금액, 보너스 포인트, 추가 할인율을 설정할 수 있습니다.
                        </div>
                      </div>
                      <div className="flex items-center gap-2">
                        <Button variant="primary" onClick={save} disabled={!dirty}>
                          저장
                        </Button>
                        <Button variant="outline" onClick={revert} disabled={!dirty}>
                          되돌리기
                        </Button>
                      </div>
                    </div>

                    <div className="rounded-2xl border border-[rgb(var(--kkeut-border))] bg-white p-6">
                      <div className="mb-4 flex items-center justify-between">
                        <h3 className="text-base font-bold">회원권 목록</h3>
                        <Button variant="primary" onClick={() => setIsAddingMembership(true)}>
                          <Plus className="mr-1 h-4 w-4" />
                          회원권 추가
                        </Button>
                      </div>

                      <div className="overflow-x-auto">
                        <table className="w-full">
                          <thead>
                            <tr className="border-b border-gray-200 text-left text-sm font-medium text-gray-600">
                              <th className="pb-3">회원권명</th>
                              <th className="pb-3">금액</th>
                              <th className="pb-3">보너스 포인트</th>
                              <th className="pb-3">추가 할인 (%)</th>
                              <th className="pb-3">상태</th>
                              <th className="pb-3 text-right">작업</th>
                            </tr>
                          </thead>
                          <tbody>
                            {memberships
                              .sort((a, b) => a.order - b.order)
                              .map((m) => (
                                <tr key={m.id} className="border-b border-gray-100">
                                  <td className="py-3 font-medium">{m.name}</td>
                                  <td className="py-3">{(m.amount / 10000).toLocaleString()}만원</td>
                                  <td className="py-3">{m.bonusPoints.toLocaleString()}P</td>
                                  <td className="py-3">{m.discountPercent}%</td>
                                  <td className="py-3">
                                    <Switch
                                      checked={m.enabled}
                                      onCheckedChange={() => {
                                        setMemberships(prev => prev.map(item =>
                                          item.id === m.id ? { ...item, enabled: !item.enabled } : item
                                        ));
                                      }}
                                    />
                                  </td>
                                  <td className="py-3 text-right">
                                    <div className="flex justify-end gap-2">
                                      <Button
                                        variant="outline"
                                        size="sm"
                                        onClick={() => setEditingMembership(m)}
                                      >
                                        수정
                                      </Button>
                                      <Button
                                        variant="outline"
                                        size="sm"
                                        onClick={() => {
                                          if (confirm(`${m.name}을(를) 삭제하시겠습니까?`)) {
                                            setMemberships(prev => prev.filter(item => item.id !== m.id));
                                          }
                                        }}
                                      >
                                        <Trash2 className="h-4 w-4" />
                                      </Button>
                                    </div>
                                  </td>
                                </tr>
                              ))}
                            {memberships.length === 0 && (
                              <tr>
                                <td colSpan={6} className="py-8 text-center text-sm text-gray-500">
                                  등록된 회원권이 없습니다
                                </td>
                              </tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                    </div>
        )}

                    {/* Membership Add/Edit Modal */}
                    {(isAddingMembership || editingMembership) && (() => {
                      const initialData = editingMembership || {
                        id: '',
                        name: '',
                        amount: 1000000,
                        bonusPoints: 0,
                        discountPercent: 0,
                        enabled: true,
                        order: memberships.length + 1,
                        createdAt: new Date().toISOString().split('T')[0] || '2025-01-01'
                      };
                      const [draft, setDraft] = React.useState(initialData);

                      return (
                        <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
                          <div className="w-full max-w-md rounded-lg bg-white p-6">
                            <div className="mb-4 flex items-center justify-between">
                              <h3 className="text-lg font-bold">
                                {editingMembership ? '회원권 수정' : '회원권 추가'}
                              </h3>
                              <button
                                onClick={() => {
                                  setIsAddingMembership(false);
                                  setEditingMembership(null);
                                }}
                                className="text-gray-400 hover:text-gray-600"
                              >
                                <X className="h-5 w-5" />
                              </button>
                            </div>

                            <div className="space-y-4">
                              <div>
                                <label className="mb-1 block text-sm font-medium">회원권명</label>
                                <Input
                                  value={draft.name}
                                  onChange={(e) => setDraft(prev => ({ ...prev, name: e.target.value }))}
                                  placeholder="예: 골드 회원권"
                                />
                              </div>

                              <div>
                                <label className="mb-1 block text-sm font-medium">금액 (만원 단위)</label>
                                <Select
                                  value={String(draft.amount)}
                                  onChange={(e) => setDraft(prev => ({ ...prev, amount: Number(e.target.value) }))}
                                >
                                  {[100, 200, 300, 500, 1000, 1500, 2000, 3000, 5000].map(val => (
                                    <option key={val} value={val * 10000}>
                                      {val}만원
                                    </option>
                                  ))}
                                </Select>
                              </div>

                              <div>
                                <label className="mb-1 block text-sm font-medium">보너스 포인트</label>
                                <Input
                                  type="number"
                                  value={draft.bonusPoints}
                                  onChange={(e) => setDraft(prev => ({ ...prev, bonusPoints: Number(e.target.value) }))}
                                  placeholder="0"
                                />
                              </div>

                              <div>
                                <label className="mb-1 block text-sm font-medium">추가 할인율 (%)</label>
                                <Input
                                  type="number"
                                  min="0"
                                  max="100"
                                  value={draft.discountPercent}
                                  onChange={(e) => setDraft(prev => ({ ...prev, discountPercent: Math.min(100, Math.max(0, Number(e.target.value))) }))}
                                  placeholder="0"
                                />
                              </div>
                            </div>

                            <div className="mt-6 flex justify-end gap-2">
                              <Button
                                variant="outline"
                                onClick={() => {
                                  setIsAddingMembership(false);
                                  setEditingMembership(null);
                                }}
                              >
                                취소
                              </Button>
                              <Button
                                variant="primary"
                                disabled={!draft.name}
                                onClick={() => {
                                  if (!draft.name) return;

                                  if (editingMembership) {
                                    setMemberships(prev => prev.map(m => m.id === draft.id ? draft : m));
                                  } else {
                                    const newMembership: MembershipItem = {
                                      ...draft,
                                      id: `membership_${Date.now()}`,
                                    };
                                    setMemberships(prev => [...prev, newMembership]);
                                  }

                                  setIsAddingMembership(false);
                                  setEditingMembership(null);
                                }}
                              >
                                {editingMembership ? '수정' : '추가'}
                              </Button>
                            </div>
                          </div>
                        </div>
                      );
                    })()}

                  </div >
                );
}
